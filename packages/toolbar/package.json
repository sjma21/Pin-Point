{
  "name": "@sajalmishra/markpin",
  "version": "0.1.0",
  "description": "Visual feedback tool for AI coding agents — click any element to annotate it",
  "keywords": ["ai", "agents", "feedback", "annotations", "mcp", "claude", "cursor", "developer-tools", "react"],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjma21/Pin-Point.git",
    "directory": "packages/toolbar"
  },
  "homepage": "https://github.com/sjma21/Pin-Point#readme",
  "bugs": {
    "url": "https://github.com/sjma21/Pin-Point/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@sajalmishra/markpin-shared": "workspace:*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
