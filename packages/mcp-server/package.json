{
  "name": "@pinpoint/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "types": "./dist/cli.d.ts",
  "main": "./dist/cli.js",
  "bin": {
    "pinpoint": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts server",
    "start": "node dist/cli.js server"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@pinpoint/shared": "workspace:*",
    "hono": "^4.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsup": "^8.1.0",
    "tsx": "^4.15.5",
    "typescript": "^5.4.5"
  }
}
