{
  "name": "@sajalmishra/markpin-shared",
  "version": "0.0.3",
  "description": "Shared TypeScript types for the Markpin annotation system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjma21/Pin-Point.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/sjma21/Pin-Point#readme",
  "bugs": {
    "url": "https://github.com/sjma21/Pin-Point/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
